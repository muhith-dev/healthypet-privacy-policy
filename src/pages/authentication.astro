---
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout meta={{ title: "HealthyPet Authentication" }}>
	<section class="max-w-3xl mx-auto py-8 text-black">
		<!-- Header -->
		<div class="bg-gradient-to-br from-[#4A5E72] to-[#5A7A9A] rounded-2xl p-6 text-white mb-8 shadow-lg">
			<div class="flex items-center gap-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
				</svg>
				<div>
					<h1 class="text-2xl font-bold m-0 text-white">HealthyPet Authentication</h1>
					<p class="text-white/80 text-sm mt-1">How authentication and user sessions are managed.</p>
				</div>
			</div>
		</div>

		<!-- Section 1: How Authentication Works -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">How Authentication Works</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100">
				<ul class="list-none space-y-3 pl-0 mb-0">
					{[
						'Users create an account using email and password.',
						'Users log in using their registered credentials.',
						'Supabase Authentication is used.',
						'User sessions are securely managed.',
						'Users are automatically redirected to Login if their session expires.',
						'Passwords are never visible.',
						'Authentication tokens are never exposed.',
						'Sensitive system credentials are never shared.'
					].map(item => (
						<li class="flex items-start gap-3 text-sm text-gray-800">
							<div class="bg-[#EBF5FB] p-1 rounded-full shrink-0 mt-0.5">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-[#4A5E72]" viewBox="0 0 20 20" fill="currentColor">
								  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
								</svg>
							</div>
							<span class="leading-relaxed">{item}</span>
						</li>
					))}
				</ul>
			</div>
		</div>

		<!-- Section 2: Role Access -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">Role Access</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 space-y-6">
				
				<div>
					<h3 class="text-base font-bold text-[#4A5E72] mb-3 flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
						Pet Owner
					</h3>
					<ul class="list-none space-y-2 pl-0 mb-0">
						{[
							'Can access their own profile.',
							'Can access their own pets.',
							'Can access their own vaccination history.',
							'Can access their own medical records.'
						].map(item => (
							<li class="flex items-start gap-2 text-sm text-gray-800 before:content-[''] before:block before:w-1.5 before:h-1.5 before:bg-[#4A5E72] before:rounded-full before:mt-1.5">{item}</li>
						))}
					</ul>
				</div>
				<hr class="border-gray-100" />
				
				<div>
					<h3 class="text-base font-bold text-[#4A5E72] mb-3 flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
						Doctor
					</h3>
					<ul class="list-none space-y-2 pl-0 mb-0">
						{[
							'Can access patient data required for medical services.',
							'Can create and manage medical records.',
							'Can manage vaccination schedules.'
						].map(item => (
							<li class="flex items-start gap-2 text-sm text-gray-800 before:content-[''] before:block before:w-1.5 before:h-1.5 before:bg-[#4A5E72] before:rounded-full before:mt-1.5">{item}</li>
						))}
					</ul>
				</div>
				<hr class="border-gray-100" />

				<div>
					<h3 class="text-base font-bold text-[#4A5E72] mb-3 flex items-center gap-2">
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
						Admin
					</h3>
					<ul class="list-none space-y-2 pl-0 mb-0">
						{[
							'Can verify doctor registrations.',
							'Can manage application users.'
						].map(item => (
							<li class="flex items-start gap-2 text-sm text-gray-800 before:content-[''] before:block before:w-1.5 before:h-1.5 before:bg-[#4A5E72] before:rounded-full before:mt-1.5">{item}</li>
						))}
					</ul>
				</div>
				
			</div>
		</div>

		<!-- Section 3: Account Deletion -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">How to Request Account Deletion</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100">
                <p class="text-sm text-gray-800 mb-3 font-semibold">Hubungi Administrator via Email:</p>
                <div class="bg-gray-50 rounded-xl p-4 border border-gray-200 text-sm text-gray-800 leading-relaxed">
                    <p class="mb-2">Kirim email permohonan ke: <a href="mailto:abdulmuhithnawawi@gmail.com" class="text-blue-600 font-bold hover:underline">abdulmuhithnawawi@gmail.com</a></p>
                    <p class="mb-2"><strong>Subjek:</strong> Permohonan Hapus Akun / Account Deletion Request</p>
                    <p class="mb-2"><strong>Isi Pesan:</strong> Cantumkan Nama Lengkap dan Email yang terdaftar di aplikasi.</p>
                    <div class="bg-red-50 p-3 rounded-lg mt-4 flex gap-3 items-start border border-red-100">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                        <p class="text-sm text-red-700 m-0"><strong>Penting:</strong> Anda <u>wajib</u> mengirimkan permohonan ini menggunakan alamat email yang sama dengan email akun yang ingin dihapus untuk verifikasi kepemilikan.</p>
                    </div>
                </div>
			</div>
		</div>
	</section>
</PageLayout>
