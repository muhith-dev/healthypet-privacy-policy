---
import PageLayout from "@/layouts/Base.astro";
---

<PageLayout meta={{ title: "Privacy & Security" }}>
	<section class="max-w-3xl mx-auto py-8 text-black">
		<!-- Header -->
		<div class="bg-gradient-to-br from-[#4A5E72] to-[#5A7A9A] rounded-2xl p-6 text-white mb-8 shadow-lg">
			<div class="flex items-center gap-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
				</svg>
				<div>
					<h1 class="text-2xl font-bold m-0 text-white">HealthyPet Privacy & Security</h1>
					<p class="text-white/80 text-sm mt-1">Informasi tentang bagaimana data Anda dilindungi dalam sistem ini.</p>
				</div>
			</div>
		</div>

		<!-- Section 1: Siapa yang dapat melihat data saya? -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">Siapa yang dapat melihat data saya?</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100">
				<p class="text-sm text-gray-800 mb-4 leading-relaxed">Dokter hewan yang menangani hewan peliharaan Anda dapat mengakses informasi berikut:</p>
				
				<div class="mb-4">
					<h3 class="text-sm font-bold text-[#4A5E72] mb-2">Data Hewan Peliharaan</h3>
					<ul class="list-none space-y-1 pl-0">
						{['Nama hewan', 'Kode hewan (Pet Code)', 'Spesies', 'Ras', 'Usia', 'Berat badan', 'Jenis kelamin', 'Foto hewan', 'Tanggal lahir'].map(item => (
							<li class="flex items-center gap-2 text-sm text-gray-800 before:content-[''] before:block before:w-1.5 before:h-1.5 before:bg-[#4A5E72] before:rounded-full">{item}</li>
						))}
					</ul>
				</div>
				
				<div class="mb-4">
					<h3 class="text-sm font-bold text-[#4A5E72] mb-2">Riwayat Medis</h3>
					<ul class="list-none space-y-1 pl-0">
						{['Riwayat vaksinasi', 'Rekam medis (diagnosa, tindakan, catatan)'].map(item => (
							<li class="flex items-center gap-2 text-sm text-gray-800 before:content-[''] before:block before:w-1.5 before:h-1.5 before:bg-[#4A5E72] before:rounded-full">{item}</li>
						))}
					</ul>
				</div>
				
				<div class="bg-[#EBF5FB] rounded-xl p-3 flex gap-3 mt-4">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-[#4A5E72] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					<p class="text-xs text-[#4A5E72] m-0 leading-relaxed">Dokter tidak dapat mengakses informasi pribadi yang tidak diperlukan untuk pelayanan medis.</p>
				</div>
			</div>
		</div>

		<!-- Section 2: Informasi pribadi saya -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">Informasi pribadi saya</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100 space-y-4">
				<div class="flex gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					<div>
						<h4 class="text-sm font-semibold text-gray-800 m-0">Nama lengkap</h4>
						<p class="text-xs text-gray-500 m-0 mt-1">Terlihat oleh dokter</p>
					</div>
				</div>
				<hr class="border-gray-100" />
				<div class="flex gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-orange-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					<div>
						<h4 class="text-sm font-semibold text-gray-800 m-0">Nomor telepon</h4>
						<p class="text-xs text-gray-500 m-0 mt-1">Opsional — hanya jika diperlukan untuk komunikasi klinik</p>
					</div>
				</div>
				<hr class="border-gray-100" />
				<div class="flex gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					<div>
						<h4 class="text-sm font-semibold text-gray-800 m-0">Kata sandi akun</h4>
						<p class="text-xs text-gray-500 m-0 mt-1">Tidak pernah ditampilkan</p>
					</div>
				</div>
				<hr class="border-gray-100" />
				<div class="flex gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					<div>
						<h4 class="text-sm font-semibold text-gray-800 m-0">Token autentikasi</h4>
						<p class="text-xs text-gray-500 m-0 mt-1">Tidak pernah ditampilkan</p>
					</div>
				</div>
				<hr class="border-gray-100" />
				<div class="flex gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
					<div>
						<h4 class="text-sm font-semibold text-gray-800 m-0">ID sistem internal</h4>
						<p class="text-xs text-gray-500 m-0 mt-1">Tidak pernah ditampilkan</p>
					</div>
				</div>
			</div>
		</div>

		<!-- Section 3: Kepemilikan data -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">Data Anda adalah milik Anda</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100">
				<p class="text-sm text-gray-800 mb-4 leading-relaxed">Sebagai pemilik hewan, Anda memiliki kendali penuh atas data pribadi dan data hewan peliharaan Anda.</p>
				
				<div class="space-y-2 mb-3">
					{['Memperbarui profil Anda', 'Memperbarui informasi hewan peliharaan', 'Melihat riwayat vaksinasi', 'Melihat rekam medis'].map(item => (
						<div class="flex items-center gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
							<span class="text-sm text-gray-800">{item}</span>
						</div>
					))}
				</div>
				<div class="space-y-2">
					{['Mengubah rekam medis dokter', 'Menghapus rekam medis dokter'].map(item => (
						<div class="flex items-center gap-3">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
							<span class="text-sm text-gray-800">{item}</span>
						</div>
					))}
				</div>
			</div>
		</div>

		<!-- Section 4: Keamanan -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">Keamanan</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100">
				<p class="text-sm text-gray-800 mb-6 leading-relaxed">Sistem melindungi data Anda melalui mekanisme keamanan berikut:</p>
				
				<div class="space-y-4">
					<div class="flex items-start gap-3">
						<div class="bg-[#EBF5FB] p-2 rounded-lg shrink-0">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
						</div>
						<div>
							<h4 class="text-sm font-bold text-gray-800 m-0">Autentikasi terlindungi</h4>
							<p class="text-xs text-gray-500 m-0 mt-1 leading-relaxed">Pengguna harus login sebelum mengakses data apapun.</p>
						</div>
					</div>
					<div class="flex items-start gap-3">
						<div class="bg-[#EBF5FB] p-2 rounded-lg shrink-0">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
						</div>
						<div>
							<h4 class="text-sm font-bold text-gray-800 m-0">Sesi terlindungi</h4>
							<p class="text-xs text-gray-500 m-0 mt-1 leading-relaxed">Pengguna tanpa sesi aktif akan diarahkan ke halaman Login.</p>
						</div>
					</div>
					<div class="flex items-start gap-3">
						<div class="bg-[#EBF5FB] p-2 rounded-lg shrink-0">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
						</div>
						<div>
							<h4 class="text-sm font-bold text-gray-800 m-0">Kontrol akses berbasis peran</h4>
							<p class="text-xs text-gray-500 m-0 mt-1 leading-relaxed">Setiap pengguna hanya dapat melihat informasi sesuai perannya.</p>
						</div>
					</div>
					<div class="flex items-start gap-3">
						<div class="bg-[#EBF5FB] p-2 rounded-lg shrink-0">
							<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>
						</div>
						<div>
							<h4 class="text-sm font-bold text-gray-800 m-0">Minimisasi data</h4>
							<p class="text-xs text-gray-500 m-0 mt-1 leading-relaxed">Hanya informasi yang diperlukan yang ditampilkan ke masing-masing peran.</p>
						</div>
					</div>
				</div>
			</div>
		</div>

		<!-- Section 5: Data yang dilindungi -->
		<div class="mb-8">
			<div class="flex items-center gap-2 mb-4">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
				</svg>
				<h2 class="text-xl font-bold text-gray-800 m-0">Data yang Dilindungi</h2>
			</div>
			<div class="bg-white rounded-2xl p-6 shadow-[0_4px_10px_rgba(0,0,0,0.03)] border border-gray-100">
				<div class="space-y-3 mb-4">
					{[
						{icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />', label: 'Informasi profil'},
						{icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5" />', label: 'Data hewan peliharaan'},
						{icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />', label: 'Rekam medis'},
						{icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />', label: 'Data vaksinasi'},
						{icon: '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />', label: 'Sesi login'}
					].map(item => (
						<div class="flex items-center gap-3 pb-2">
							<div class="bg-gray-100 p-1.5 rounded-lg shrink-0">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#4A5E72]" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={item.icon} />
							</div>
							<span class="text-sm text-gray-800">{item.label}</span>
							<div class="ml-auto">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-green-500" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
							</div>
						</div>
					))}
				</div>
				
				<div class="bg-green-50 rounded-xl p-3 flex gap-3">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-green-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
					</svg>
					<p class="text-xs text-green-700 font-semibold m-0 leading-relaxed">Kata sandi Anda tidak pernah ditampilkan di dalam aplikasi.</p>
				</div>
			</div>
		</div>
	</section>
</PageLayout>
